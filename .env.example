# ===================== PostgreSQL =====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===================== JWT =====================
JWT_SECRET=your-secret-key-min-32-chars-here

# ===================== Service-to-service (field ↔ weather ↔ analytics) =====================
# Одинаковое значение на field-service, weather-service, analytics-service
INTERNAL_API_TOKEN=dev-internal-token

# ===================== Analytics external APIs =====================
FIELD_SERVICE_URL=http://field-service:8082
OPEN_METEO_BASE_URL=https://api.open-meteo.com

# ===================== Weather service (Spring env) =====================
# URL field-service for startup sync of lat/lng (Docker: http://field-service:8082)
AGRO_FIELD_SERVICE_BASE_URL=http://field-service:8082

# ===================== Telegram (notification-service, optional) =====================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
