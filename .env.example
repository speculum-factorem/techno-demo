# ===================== Required secrets/config =====================
# Важно: POSTGRES_USER/PASSWORD задают суперпользователя только при ПЕРВОМ создании тома postgres.
# Если том уже есть, смена здесь не обновит пароль в БД — будет "password authentication failed".
POSTGRES_USER=agro_user
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-super-long-random-secret-min-32-chars
INTERNAL_API_TOKEN=change-me-internal-service-token
# Список точных Origin (через запятую). Для продакшена по IP добавьте: http://ВАШ_IP
# Без этого браузер шлёт Origin http://IP → Spring CORS отвечает 403 на /api/auth/register и др.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Опционально: явные шаблоны вместо перечисления IP (в образах с профилем docker уже стоят http://*,https://*)
# APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://*,https://*
# Для VPS укажите публичный URL фронта (порт 80 с docker-compose.prod.yml): http://ВАШ_IP или https://домен
FRONTEND_URL=http://localhost:3000
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
BOOTSTRAP_AGRONOMIST_PASSWORD=change-me-agronomist-password
BOOTSTRAP_INVITE_CODE=ORG1-INVITE-2026

# ===================== Optional auth/mail =====================
REGISTER_RATE_LIMIT_REQUESTS=5
REGISTER_RATE_LIMIT_WINDOW_SECONDS=900
VERIFICATION_TTL_MINUTES=1440
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ===================== Service URLs =====================
FIELD_SERVICE_URL=http://field-service:8082
OPEN_METEO_BASE_URL=https://api.open-meteo.com
AGRO_FIELD_SERVICE_BASE_URL=http://field-service:8082

# ===================== Запуск на удалённом сервере =====================
# Скопируйте этот файл в .env, задайте секреты и URL. Затем из каталога techno-demo:
# docker compose --env-file .env -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# (если нет плагина compose: sudo apt install docker-compose-plugin или пакет docker-compose)

# ===================== Kafka (optional tuning) =====================
# На очень слабом VPS можно уменьшить heap в docker-compose.yml (KAFKA_HEAP_OPTS)

# ===================== Telegram (optional) =====================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
