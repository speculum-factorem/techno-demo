{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3000
    },
    {
      "name": "analytics-service",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend/analytics-service && python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload"],
      "port": 8000
    }
  ]
}
